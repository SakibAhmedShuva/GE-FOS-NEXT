# PostgreSQL database used by Prisma
DATABASE_URL="postgresql://fos_user:fos_password@localhost:5432/financial_offer_system?schema=public"

# Session/cookie signing secret. Generate a long random value in production.
SESSION_SECRET="replace-with-a-long-random-secret"

# Storage root for migrated covers, exports, chat attachments, imports, and assets.
FOS_STORAGE_ROOT="./storage"

# Legacy import/audit source folder. Do not commit real legacy data into the app repository.
LEGACY_FOS_ROOT="/absolute/path/to/Financial-Offer-Challan-Purchase-Order-System Stable"

# PDF document asset stamping. Assets are storage keys inside FOS_STORAGE_ROOT.
FOS_PDF_ASSET_MODE="letterhead-only"
FOS_LETTERHEAD_STORAGE_KEY="assets/letterhead.pdf"
# Optional: use different letterhead PDFs for first/continuation pages.
# FOS_LETTERHEAD_FIRST_PAGE_STORAGE_KEY="assets/letterhead-first.pdf"
# FOS_LETTERHEAD_CONTINUATION_STORAGE_KEY="assets/letterhead-continuation.pdf"
# Leave logo empty when the letterhead PDF already contains the logo.
FOS_LOGO_STORAGE_KEY=""
FOS_SIGNATURE_STORAGE_KEY="assets/signatures/Signature_default.png"
FOS_PO_INCLUDE_SIGNATURE="false"
# Optional PDF coordinates in points, origin bottom-left.
# FOS_LOGO_X="461"
# FOS_LOGO_Y="770"
# FOS_LOGO_MAX_WIDTH="92"
# FOS_LOGO_MAX_HEIGHT="42"
# FOS_SIGNATURE_X="421"
# FOS_SIGNATURE_Y="54"
# FOS_SIGNATURE_MAX_WIDTH="120"
# FOS_SIGNATURE_MAX_HEIGHT="55"
# Optional document-specific logo selection. Leave these empty unless the letterhead does not already include branding.
# FOS_OFFER_LOGO_STORAGE_KEY="assets/amoge_logo.png"
# FOS_CHALLAN_LOGO_STORAGE_KEY="assets/amoge_logo.png"
# FOS_PURCHASE_ORDER_LOGO_STORAGE_KEY="assets/NAFFCO_Logo_New.png"
# Optional fixed Purchase Order signatory fallback. Used only when FOS_PO_INCLUDE_SIGNATURE=true and no PO owner signature key exists.
# FOS_PO_SIGNATURE_STORAGE_KEY="assets/signatures/Signature_PO.png"
